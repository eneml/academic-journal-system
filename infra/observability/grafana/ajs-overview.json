{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Operational overview for the AJS backend — JVM, HTTP throughput, DB pool, deposit outbox.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Up",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [
        {"expr": "up{job=\"ajs-backend\"}", "legendFormat": "{{instance}}", "refId": "A"}
      ],
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}}
    },
    {
      "type": "stat",
      "title": "Request rate (req/s)",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 4, "w": 5, "x": 4, "y": 0},
      "targets": [
        {"expr": "sum(rate(http_server_requests_seconds_count[1m]))", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "5xx error rate",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 4, "w": 5, "x": 9, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [
        {"color": "green", "value": null},
        {"color": "yellow", "value": 0.01},
        {"color": "red", "value": 0.02}
      ]}}}
    },
    {
      "type": "stat",
      "title": "JVM heap (%)",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 4, "w": 5, "x": 14, "y": 0},
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) / sum(jvm_memory_max_bytes{area=\"heap\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p50/p95/p99",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "Top endpoints by request rate",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "topk(10, sum by (uri) (rate(http_server_requests_seconds_count[5m])))", "legendFormat": "{{uri}}", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Hikari pool: active vs idle",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "hikaricp_connections_active", "legendFormat": "active {{pool}}", "refId": "A"},
        {"expr": "hikaricp_connections_idle", "legendFormat": "idle {{pool}}", "refId": "B"}
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM heap & non-heap (MB)",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "sum(jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "heap used", "refId": "A"},
        {"expr": "sum(jvm_memory_used_bytes{area=\"nonheap\"})", "legendFormat": "non-heap used", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ajs", "spring-boot"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "AJS — Backend overview",
  "uid": "ajs-overview",
  "version": 1,
  "weekStart": "",
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"}
  ]
}
