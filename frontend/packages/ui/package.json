{
  "name": "@ajs/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./primitives": {
      "types": "./src/primitives/index.ts",
      "import": "./src/primitives/index.ts"
    },
    "./lib/cn": {
      "types": "./src/lib/cn.ts",
      "import": "./src/lib/cn.ts"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "build": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@ajs/tsconfig": "workspace:*",
    "@types/react": "^19.0.2",
    "react": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
