{
  "name": "@ajs/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./primitives": {
      "types": "./src/primitives/index.ts",
      "import": "./src/primitives/index.ts"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "build": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@ajs/tsconfig": "workspace:*",
    "@types/react": "^19.0.2",
    "react": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
