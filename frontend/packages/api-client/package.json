{
  "name": "@ajs/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "openapi --input http://localhost:8080/v3/api-docs --output src/generated --client fetch",
    "type-check": "tsc --noEmit",
    "build": "tsc --noEmit",
    "clean": "rm -rf dist .turbo src/generated *.tsbuildinfo"
  },
  "devDependencies": {
    "@ajs/tsconfig": "workspace:*",
    "openapi-typescript-codegen": "^0.29.0",
    "typescript": "^5.7.2"
  }
}
