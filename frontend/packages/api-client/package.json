{
  "name": "@ajs/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.d.ts"
    }
  },
  "scripts": {
    "generate": "openapi-typescript ${OPENAPI_URL:-http://localhost:8080/v3/api-docs} --output src/schema.d.ts",
    "type-check": "tsc --noEmit",
    "build": "tsc --noEmit",
    "clean": "rm -rf dist .turbo src/schema.d.ts *.tsbuildinfo"
  },
  "devDependencies": {
    "@ajs/tsconfig": "workspace:*",
    "openapi-typescript": "^7.5.0",
    "typescript": "^5.7.2"
  }
}
